#include<iostream>
using namespace std;

int main()
{
    int arr[100],n,sum =0;
    //enter elements
    cout<<"enter number elements:";
    cin>>n;
    for(int i = 0;i<n;i++){
        cin>>arr[i];
    }
    //print array
    cout<<"sum of elemets is:";
    for(int i=0;i<n;i++){
        sum +=arr[i];
       
    }
    cout<<sum<<endl;
    return 0;
}
