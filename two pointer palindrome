#include <iostream>
using namespace std;

int main()
{
    string str;

    cout << "Enter a string: ";
    cin >> str;

    int left = 0;
    int right = str.length() - 1;

    bool palindrome = true;

    while (left < right)
    {
        if (str[left] != str[right])
        {
            palindrome = false;
            break;
        }

        left++;
        right--;
    }

    if (palindrome)
    {
        cout << "Palindrome" << endl;
    }
    else
    {
        cout << "Not Palindrome" << endl;
    }

    return 0;
}
