#include <iostream>
using namespace std;

int main()
{
    int n;
    bool isPrime = true;
    cout<<"Enter the number:"<<endl;
    cin>>n;
    for(int i=2;i*i<n-1;i++){
        if(n%i==0){
            isPrime = false;
            break;
        }
       
    }
    if(isPrime){
        cout<<"prime number"<<endl;
    }
    else
    {
        cout<<"Not prime Number"<<endl;
    }
    return 0;
}
    
    
