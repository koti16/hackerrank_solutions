#include<iostream>
using namespace std;

int main (){
    string str ;
    cout<<"enter a string:"<<endl;
    cin>>str;
    int upper =0;
    int special =0;
    int lower = 0;
    int digit =0;
    
    
    for(int i = 0; i < str.length(); i++)
{
    char ch = str[i];

    if(ch >= 'A' && ch <= 'Z')
    {
        upper++;
    }
    else if(ch >= 'a' && ch <= 'z')
    {
        lower++;
    }
    else if(ch >= '0' && ch <= '9')
    {
        digit++;
    }
    else
    {
        special++;
    }
}
cout<<"upper:"<<upper<<endl;
cout<<"special :"<<special<<endl;
cout<<"lower"<<lower<<endl;
cout<< "digit :"<<digit<<endl;

    
    
    return 0;
    
    
}
