#include<iostream>
using namespace std;

int main (){
    string str ;
    cout<<"Enter an string:"<<endl;
    cin>>str;
    string vowel = "aeiou";
    
    int vowels =0;
    int consonants =0;
    
    
    for(int i=0;i<str.length();i++){
        
        char ch = tolower(str[i]);
        
        if (ch == 'a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'){
            vowels++;
        }
        else if(ch>='a' && ch<='z')
        {
            consonants++;
        }
        
        
    }
    cout<<"vowels:"<<vowels<<endl;
    cout<<"consonants:"<<consonants<<endl;
    
    return 0;
    
}
    
