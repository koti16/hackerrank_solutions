#include<iostream>
using namespace std;

int main (){
    int arr[100],n,i;
    bool sorted = true;
    cout<<"enter no.of elements:"<<endl;
    cin>>n;
    
    
    cout<<"array elements are :"<<endl;
    for(int i=0;i<n;i++){
       cin>>arr[i];
    }
    
   for(int i=0;i<n-1;i++){
       if(arr[i]>arr[i+1]){
           sorted =false;
           break;
       }
   }
   if(sorted){
       cout<<"Array is sorted"<<endl;
   }
   else
   {
       cout<<"Array is not sorted"<<endl;
       
   }
    return 0;
}
