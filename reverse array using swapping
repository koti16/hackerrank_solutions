#include <iostream>
#include <string>
using namespace std;

int main() {
    int n,arr[100],i,temp;
    cout<<"enter no.of elements:"<<endl;
    cin>>n;
    
    cout<<"enter the elements:"<<endl;
    for(int i=0;i<n;i++){
        cin>>arr[i];
        
    }
    
    int left=0;
    int right =n-1;
    while(left<right){
        //swap
        temp=arr[left];
        arr[left]=arr[right];
        arr[right]=temp;
        
        left++;
        right--;
        
    }
    cout<<"Reversed array is:"<<endl;
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
    
    return 0;
}
