#include<iostream>
using namespace std;

int main() {
    int arr[100], n;

    cout << "Enter no.of array elements: ";
    cin >> n;

    cout << "Enter elements of array:" << endl;
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    for(int i = 0; i < n; i++) {

        // Check if this element was already counted
        bool alreadyCounted = false;

        for(int j = 0; j < i; j++) {
            if(arr[i] == arr[j]) {
                alreadyCounted = true;
                break;
            }
        }

        // Skip duplicate occurrences
        if(alreadyCounted) {
            continue;
        }

        // Count frequency
        int count = 0;
        for(int j = 0; j < n; j++) {
            if(arr[i] == arr[j]) {
                count++;
            }
        }

        cout << arr[i] << " occurs " << count << " times" << endl;
    }

    return 0;
}
