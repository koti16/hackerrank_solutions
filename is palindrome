#include<iostream>
using namespace std;

int main (){
   
   string str,rev="";
   cout<<"enter an string :"<<endl;
   cin>>str;
  
   cout<<"reverse string is:"<<endl;
   for(int i =str.length()-1;i>=0;i--){
       
       rev+=str[i];
   }
   
   if(str==rev){
       cout<<"is Palindrome"<<endl;
   }
   else{
       cout<<"not a Palindrome"<<endl;
   }
   
    return 0;
    
}
    
