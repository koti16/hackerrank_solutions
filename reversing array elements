#include<iostream>
using namespace std;

int main()
{
    int arr[100],n;
    //enter elements
    cout<<"enter number of elements:";
    cin>>n;
    
    for(int i = 0;i<n;i++)
    {
        cin>>arr[i];
    }
    cout<<"reverse array elements are:"<<endl;
    for(int i=n-1;i>=0;i--){
        cout<<arr[i]<<" ";
    }
    
    return 0;
}
