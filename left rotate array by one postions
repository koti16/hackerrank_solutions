#include<iostream>
using namespace std;

int main (){
    int n,arr[500];
    cout<<"Enter no.of array elements:"<<endl;
    cin>>n;
    
    cout<<"enter array elements:"<<endl;
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    
    cout<<"intial array elements is:\n"<<endl;
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
    cout<<"array after left rotate array by onr postion:\n"<<endl;
    int temp = arr[0];
    for(int i=0;i<n-1;i++){
        arr[i]=arr[i+1];
        
    
    }
    arr[n-1]=temp;
    cout << "Rotated array is:" << endl;
    for(int i=0 ;i<n;i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}
