#include<iostream>
using namespace std;

int main()
{
    int arr[100],n;
    //enter elements
    cout<<"enter number of elements:";
    cin>>n;
    
    for(int i = 0;i<n;i++)
    {
        cin>>arr[i];
    }
    //print array
    int max = arr[0];
    for(int i=0;i<n;i++){
        
        if(arr[i]>max)
        {
            max =arr[i];
            
        }
    }
    
    cout<<"mix element:"<<max<<endl;
        
  
    
    return 0;
}
